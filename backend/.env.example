# Copy to `.env` and adjust. The API loads `.env` on startup via dotenv.
GOOGLE_OAUTH_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
# Optional native clients (must be listed if you verify tokens issued to those apps):
# GOOGLE_OAUTH_ANDROID_CLIENT_ID=
# GOOGLE_OAUTH_IOS_CLIENT_ID=

# MySQL (Render / managed DB — never use docker defaults in production)
# DB_HOST=
# DB_PORT=3306
# DB_USER=
# DB_PASSWORD=
# DB_NAME=
# DB_POOL_LIMIT=10

# CORS: comma-separated exact browser Origins. If unset, any Origin is accepted (dev only).
# Example: https://your-app.vercel.app,http://localhost:5000
# CORS_ALLOWED_ORIGINS=
